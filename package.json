{
  "name": "landview-buyback",
  "version": "1.0.0",
  "description": "Landview Buyback System - Monorepo",
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "db:setup": "cd backend && npx prisma migrate dev --name init && npm run prisma:seed",
    "db:seed": "npm run prisma:seed --prefix backend",
    "db:studio": "npm run prisma:studio --prefix backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
