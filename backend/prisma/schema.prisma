generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  super_admin
  admin
  accountant
}

enum InvestmentStatus {
  active
  completed
  extended
  payment_initiated
}

enum ActionType {
  LOGIN
  LOGOUT
  FAILED_LOGIN
  CREATE_INVESTMENT
  UPDATE_INVESTMENT
  DELETE_INVESTMENT
  EXTEND_INVESTMENT
  PAYMENT_INITIATED
  PAYMENT_COMPLETED
  CREATE_USER
  UPDATE_USER
  DELETE_USER
  AI_UPLOAD
  EMAIL_SENT
  APPLICATION_SUBMITTED
  APPLICATION_APPROVED
  APPLICATION_REJECTED
  SEND_MATURITY_REMINDERS
  CLIENT_INTENTION_RECEIVED
  MARK_UPFRONT_PAID
}

enum ApplicationStatus {
  pending
  approved
  rejected
  converted
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  passwordHash String
  fullName  String
  role      Role     @default(accountant)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  createdBy String?

  createdByUser     User?  @relation("CreatedBy", fields: [createdBy], references: [id])
  createdUsers      User[] @relation("CreatedBy")
  investments       Investment[] @relation("CreatedByUser")
  auditLogs         AuditLog[]
  paymentInitiated  Investment[] @relation("PaymentInitiatedBy")
  paymentCompleted  Investment[] @relation("PaymentCompletedBy")
  reviewedApplications ClientApplication[] @relation("ApplicationReviewer")

  @@map("users")
}

model Investment {
  id                  String           @id @default(uuid())
  transactionDate     DateTime
  clientName          String
  plotNumber          String
  duration            String
  maturityDate        DateTime
  principal           Decimal          @db.Decimal(15, 2)
  interestRate        Decimal          @db.Decimal(5, 2)
  roiAmount           Decimal          @db.Decimal(15, 2)
  upfrontPayment      Decimal?         @db.Decimal(15, 2)
  maturityAmount      Decimal          @db.Decimal(15, 2)
  clientEmail         String?
  realtorName         String
  realtorEmail        String
  status              InvestmentStatus @default(active)
  documentUrl         String?
  paymentInitiatedAt  DateTime?
  paymentCompletedAt  DateTime?
  upfrontPaidAt       DateTime?
  responseToken       String?          @unique
  clientIntention     String?
  clientIntentionMessage String?
  clientIntentionAt   DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt

  createdBy           String
  createdByUser       User             @relation("CreatedByUser", fields: [createdBy], references: [id])
  paymentInitiatedBy  String?
  paymentInitiatedUser User?           @relation("PaymentInitiatedBy", fields: [paymentInitiatedBy], references: [id])
  paymentCompletedBy  String?
  paymentCompletedUser User?           @relation("PaymentCompletedBy", fields: [paymentCompletedBy], references: [id])

  extensions          InvestmentExtension[]
  application         ClientApplication?

  @@map("investments")
}

model InvestmentExtension {
  id              String     @id @default(uuid())
  investmentId    String
  investment      Investment @relation(fields: [investmentId], references: [id])
  previousDuration String
  newDuration     String
  previousMaturityDate DateTime
  newMaturityDate DateTime
  previousInterestRate Decimal @db.Decimal(5, 2)
  newInterestRate Decimal @db.Decimal(5, 2)
  extendedAt      DateTime   @default(now())
  extendedBy      String

  @@map("investment_extensions")
}

model ClientApplication {
  id                  String            @id @default(uuid())

  // Personal
  title               String?
  surname             String
  otherNames          String
  dateOfBirth         String?
  sex                 String?
  maritalStatus       String?
  nationality         String?
  countryOfResidence  String?
  phoneNumber         String
  alternativePhone    String?
  clientEmail         String?

  // Address
  correspondenceAddress String?
  correspondenceCity  String?
  correspondenceState String?
  permanentAddress    String?
  permanentCity       String?
  permanentState      String?
  country             String?

  // Corporate
  isCorporate         Boolean           @default(false)
  corporateName       String?
  corporateAddress    String?

  // Next of Kin
  nextOfKinName       String?
  nextOfKinEmail      String?
  nextOfKinPhone      String?

  // Investment
  duration            String
  principal           Decimal           @db.Decimal(15, 2)
  wantsUpfront        Boolean           @default(false)

  // Payment
  paymentMode         String?
  accountName         String?
  accountNumber       String?
  bankName            String?

  // Source of funds (JSON array stored as string)
  sourceOfFunds       String?

  // Realtor
  realtorName         String?
  realtorEmail        String?
  realtorPhone        String?

  // Agreement
  agreedToTerms       Boolean           @default(false)

  // Status workflow
  status              ApplicationStatus @default(pending)
  rejectionReason     String?
  clientMessage       String?

  // Review
  reviewedBy          String?
  reviewedAt          DateTime?
  reviewer            User?             @relation("ApplicationReviewer", fields: [reviewedBy], references: [id])

  // Linked investment (set when converted)
  investmentId        String?           @unique
  investment          Investment?       @relation(fields: [investmentId], references: [id])

  submittedAt         DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@map("client_applications")
}

model AuditLog {
  id           String     @id @default(uuid())
  userId       String?
  user         User?      @relation(fields: [userId], references: [id])
  actionType   ActionType
  entityType   String
  entityId     String?
  oldValues    Json?
  newValues    Json?
  ipAddress    String?
  userAgent    String?
  description  String?
  createdAt    DateTime   @default(now())

  @@map("audit_logs")
}

model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  updatedBy String?

  @@map("system_settings")
}
